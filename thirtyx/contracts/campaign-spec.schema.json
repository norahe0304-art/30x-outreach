{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://30x.example/schemas/campaign-spec.schema.json",
  "title": "30x Outreach Campaign Spec",
  "type": "object",
  "required": [
    "schema_version",
    "campaign_id",
    "sequence_version",
    "audience",
    "anti_icp",
    "buyer_problem",
    "value_proposition",
    "evidence",
    "experiment",
    "steps"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "campaign_id": {"type": "string", "minLength": 1},
    "sequence_version": {"type": "string", "minLength": 1},
    "audience": {"type": "string", "minLength": 1},
    "anti_icp": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
    "buyer_problem": {"type": "string", "minLength": 1},
    "value_proposition": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "experiment": {"$ref": "#/$defs/experiment"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    }
  },
  "$defs": {
    "threshold": {
      "type": "object",
      "required": ["operator", "value"],
      "properties": {
        "operator": {"enum": ["<", "<=", ">", ">="]},
        "value": {"type": "number"}
      },
      "additionalProperties": false
    },
    "guardrail": {
      "type": "object",
      "required": ["metric", "operator", "value"],
      "properties": {
        "metric": {"type": "string", "minLength": 1},
        "operator": {"enum": ["<", "<=", ">", ">="]},
        "value": {"type": "number"}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["id", "observation", "source", "verified"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "observation": {"type": "string", "minLength": 1},
        "source": {"type": "string", "format": "uri"},
        "verified": {"const": true}
      },
      "additionalProperties": false
    },
    "experiment": {
      "type": "object",
      "required": ["hypothesis", "variable", "primary_metric", "guardrails", "minimum_sample_size", "decision_thresholds"],
      "properties": {
        "hypothesis": {"type": "string", "minLength": 1},
        "variable": {"type": "string", "minLength": 1},
        "primary_metric": {"type": "string", "minLength": 1},
        "guardrails": {"type": "array", "items": {"$ref": "#/$defs/guardrail"}},
        "minimum_sample_size": {"type": "integer", "minimum": 1},
        "decision_thresholds": {
          "type": "object",
          "required": ["scale", "kill", "learn"],
          "properties": {
            "scale": {"$ref": "#/$defs/threshold"},
            "kill": {"$ref": "#/$defs/threshold"},
            "learn": {
              "type": "object",
              "required": ["otherwise"],
              "properties": {"otherwise": {"const": true}},
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["day", "subject", "body", "cta", "evidence_ids"],
      "properties": {
        "day": {"type": "integer", "minimum": 0},
        "subject": {"type": "string"},
        "body": {"type": "string", "minLength": 1},
        "cta": {"type": "string"},
        "evidence_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
