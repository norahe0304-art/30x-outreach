{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://30x.example/schemas/decision-record.schema.json",
  "title": "30x Outreach Decision Record",
  "type": "object",
  "required": [
    "schema_version",
    "campaign_id",
    "sequence_version",
    "decision",
    "reason",
    "sample_size",
    "primary_metric",
    "primary_value",
    "failed_guardrails",
    "missing_metrics"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "campaign_id": {"type": "string", "minLength": 1},
    "sequence_version": {"type": "string", "minLength": 1},
    "decision": {"enum": ["COLLECT", "SCALE", "KILL", "LEARN"]},
    "reason": {"type": "string", "minLength": 1},
    "sample_size": {"type": "integer", "minimum": 0},
    "primary_metric": {"type": "string", "minLength": 1},
    "primary_value": {"type": ["number", "null"]},
    "failed_guardrails": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_metrics": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "additionalProperties": false
}
