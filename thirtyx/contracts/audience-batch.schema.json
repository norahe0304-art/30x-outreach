{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://30x.example/schemas/audience-batch.schema.json",
  "title": "30x Outreach Audience Batch",
  "type": "object",
  "required": ["schema_version", "campaign_id", "generated_at", "leads"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "campaign_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "leads": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/lead"}
    }
  },
  "$defs": {
    "verification": {
      "type": "object",
      "required": ["status", "provider", "checked_at", "is_free_email", "is_role_based"],
      "properties": {
        "status": {"const": "valid"},
        "provider": {"type": "string", "minLength": 1},
        "checked_at": {"type": "string", "format": "date-time"},
        "is_free_email": {"const": false},
        "is_role_based": {"const": false}
      },
      "additionalProperties": false
    },
    "signal": {
      "type": "object",
      "required": ["id", "observation", "source", "observed_at", "verified"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "observation": {"type": "string", "minLength": 1},
        "source": {"type": "string", "format": "uri"},
        "observed_at": {"type": "string", "format": "date-time"},
        "verified": {"const": true}
      },
      "additionalProperties": false
    },
    "lead": {
      "type": "object",
      "required": ["email", "verification", "signals"],
      "properties": {
        "email": {"type": "string", "format": "email"},
        "first_name": {"type": "string"},
        "last_name": {"type": "string"},
        "company_name": {"type": "string"},
        "verification": {"$ref": "#/$defs/verification"},
        "signals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/signal"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
